{%- set default_cable = '5m' %}
{% set ingress_lossless_pool_size =  '20971328' %}
{% set ingress_lossy_pool_size =  '20971328' %}

{%- macro generate_buffer_pool_and_profiles() %}
    "BUFFER_POOL": {
        "ingress_lossless_pool": {
            "size": "{{ ingress_lossless_pool_size }}",
            "type": "ingress",
            "mode": "dynamic"
        },
        "ingress_lossy_pool": {
            "size": "{{ ingress_lossy_pool_size }}",
            "type": "ingress",
            "mode": "dynamic"
        }
    },
    "BUFFER_PROFILE": {
        "ingress_lossless_profile": {
            "pool":"ingress_lossless_pool",
            "size":"41808",
            "dynamic_th":"-4"
        },
        "ingress_lossy_profile": {
            "pool":"ingress_lossy_pool",
            "size":"3584",
            "dynamic_th":"-1"
        }
    },
{%- endmacro %}

{%- macro generate_pg_profils(port_names_list_active) %}
    "BUFFER_PG": {
{% for port in port_names_list_active.split(',') %}
        "{{ port }}|0": {
            "profile" : "ingress_lossy_profile"
        },
        "{{ port }}|3": {
            "profile" : "ingress_lossless_profile"
        }
        {% if not loop.last %},{% endif %}
{% endfor %}
    },
{%- endmacro %}

{# Default, we do not bind any buffer queues. #}
{%- macro generate_queue_buffers(port_names_list_active) %}
    "BUFFER_QUEUE": {
    }
{%- endmacro %}
