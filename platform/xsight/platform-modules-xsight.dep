MPATH       := $($(XSIGHT_X2EVB_PLATFORM_MODULE)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/platform-modules-xsight.mk $(PLATFORM_PATH)/platform-modules-xsight.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(MPATH))

$(XSIGHT_X2EVB_PLATFORM_MODULE)_CACHE_MODE  := GIT_CONTENT_SHA
$(XSIGHT_X2EVB_PLATFORM_MODULE)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(XSIGHT_X2EVB_PLATFORM_MODULE)_DEP_FILES   := $(DEP_FILES)

