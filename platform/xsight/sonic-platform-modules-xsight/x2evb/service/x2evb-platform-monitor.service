[Unit]
Description=Xsight X2EVB Platform Service
Before=pmon.service
After=sysinit.target
DefaultDependencies=no

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/x2evb_util.sh init
ExecStop=/usr/local/bin/x2evb_util.sh deinit
KillSignal=SIGKILL
SuccessExitStatus=SIGKILL

[Install]
WantedBy=multi-user.target
