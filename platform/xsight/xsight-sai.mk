# XSight SAI
XSIGHT_LIBSAI = xsai-main_0.1_all.deb
XSIGHT_URL =
XSIGHT_LIBSAI_DEB_LOCAL = /sonic
export XSIGHT_LIBSAI_DEB_LOCAL

ifneq ($(XSIGHT_LIBSAI_DEB_LOCAL), )
SAI_FROM_LOCAL = y
else
SAI_FROM_LOCAL = n
endif

ifeq ($(SAI_FROM_LOCAL), y)
$(XSIGHT_LIBSAI)_PATH = $(XSIGHT_LIBSAI_DEB_LOCAL)
else
$(XSIGHT_LIBSAI)_URL = $(XSIGHT_URL)
endif

ifeq ($(SAI_FROM_LOCAL), y)
SONIC_COPY_DEBS += $(XSIGHT_LIBSAI)
else
SONIC_ONLINE_DEBS += $(XSIGHT_LIBSAI)
endif
